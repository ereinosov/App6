<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FragmentClientes">

    <!-- TODO: Update blank fragment layout -->

    <ImageView
        android:id="@+id/imgClientes"
        android:layout_width="125dp"
        android:layout_height="203dp"
        android:src="@drawable/clients"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Clientes"
        android:textAlignment="center"
        android:textStyle="bold"
        android:textSize="24sp"

        app:layout_constraintEnd_toEndOf="@+id/imgClientes"
        app:layout_constraintStart_toStartOf="@+id/imgClientes"
        app:layout_constraintTop_toBottomOf="@+id/imgClientes" />
</androidx.constraintlayout.widget.ConstraintLayout>